generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IngredientType {
  PROTEIN
  CARB
  VEG
  FRUIT
  EXTRA
}

enum StoreTag {
  COSTCO
  CUB
  OTHER
}

enum CostTier {
  BUDGET
  STANDARD
  PREMIUM
}

model Meal {
  id           String           @id @default(cuid())
  name         String
  category     String
  costTier     CostTier
  kidFavorite  Boolean          @default(false)
  lowEffort    Boolean          @default(false)
  notes        String?
  ingredients  MealIngredient[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Ingredient {
  id          String           @id @default(cuid())
  name        String
  type        IngredientType
  storeTag    StoreTag         @default(OTHER)
  meals       MealIngredient[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model MealIngredient {
  mealId        String
  ingredientId  String
  quantityLabel String?
  meal          Meal       @relation(fields: [mealId], references: [id], onDelete: Cascade)
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@id([mealId, ingredientId])
}

model WeeklyPlan {
  id            String           @id @default(cuid())
  weekStartDate DateTime
  meals         WeeklyPlanMeal[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model WeeklyPlanMeal {
  id           String     @id @default(cuid())
  weeklyPlanId String
  mealId       String
  dayOfWeek    Int
  weeklyPlan   WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  meal         Meal       @relation(fields: [mealId], references: [id], onDelete: Cascade)
}
