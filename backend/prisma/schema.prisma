generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IngredientType {
  PROTEIN
  CARB
  VEG
  FRUIT
  EXTRA
}

enum CostTier {
  BUDGET
  STANDARD
  PREMIUM
}

model Category {
  id              String             @id @default(cuid())
  name            String
  slug            String             @unique
  iconId          String?
  weeklyMinCount  Int?
  weeklyMaxCount  Int?
  meals           Meal[]
  slotAssignments CategoryPlanSlot[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model PlanSlot {
  id                  String             @id @default(cuid())
  name                String
  slug                String             @unique
  sortOrder           Int
  isEnabled           Boolean            @default(true)
  categoryAssignments CategoryPlanSlot[]
  planMeals           WeeklyPlanMeal[]
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model CategoryPlanSlot {
  categoryId String
  planSlotId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  planSlot   PlanSlot @relation(fields: [planSlotId], references: [id], onDelete: Restrict)

  @@id([categoryId, planSlotId])
}

model StoreTagOption {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  ingredients Ingredient[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Meal {
  id           String           @id @default(cuid())
  name         String
  slug         String           @unique
  categoryId   String
  category     Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  costTier     CostTier
  kidFavorite  Boolean          @default(false)
  lowEffort    Boolean          @default(false)
  notes        String?
  ingredients  MealIngredient[]
  planMeals    WeeklyPlanMeal[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
}

model Ingredient {
  id          String           @id @default(cuid())
  name        String           @unique
  type        IngredientType
  storeTagId  String?
  storeTag    StoreTagOption?  @relation(fields: [storeTagId], references: [id], onDelete: SetNull)
  meals       MealIngredient[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model MealIngredient {
  mealId        String
  ingredientId  String
  quantityLabel String?
  meal          Meal       @relation(fields: [mealId], references: [id], onDelete: Cascade)
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@id([mealId, ingredientId])
}

model WeeklyPlan {
  id            String           @id @default(cuid())
  weekStartDate DateTime         @unique
  meals         WeeklyPlanMeal[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model WeeklyPlanMeal {
  id           String     @id @default(cuid())
  weeklyPlanId String
  mealId       String
  dayOfWeek    Int
  planSlotId   String
  weeklyPlan   WeeklyPlan @relation(fields: [weeklyPlanId], references: [id], onDelete: Cascade)
  meal         Meal       @relation(fields: [mealId], references: [id], onDelete: Cascade)
  planSlot     PlanSlot   @relation(fields: [planSlotId], references: [id], onDelete: Restrict)

  @@unique([weeklyPlanId, dayOfWeek, planSlotId])
}
